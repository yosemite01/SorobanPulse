# PostgreSQL credentials (used by both the db service and the app's DATABASE_URL)
POSTGRES_USER=<USER>
POSTGRES_PASSWORD=<PASSWORD>
POSTGRES_DB=soroban_pulse

# Deployment environment (development / staging / production)
# Controls strictness of CORS and other defaults.
ENVIRONMENT=development

# PostgreSQL connection string — must match the credentials above
# Format: postgres://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>
DATABASE_URL=postgres://<USER>:<PASSWORD>@db:5432/soroban_pulse

# Optional: read DATABASE_URL from a file (Docker secrets / Kubernetes secret mount)
# When set, this takes precedence over DATABASE_URL
# DATABASE_URL_FILE=/run/secrets/database_url

# PostgreSQL connection pool sizing
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1

# Soroban RPC endpoint URL — must be a valid HTTPS URL in production
# Format: https://<domain> or http://<ip>:<port>
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Allow HTTP or loopback/private RPC URLs (local dev only — never set in production)
# ALLOW_INSECURE_RPC=true

# Ledger sequence number to start indexing from (0 = latest)
# Format: integer (e.g., 0, 123456)
START_LEDGER=0

# HTTP server port to listen on
# Format: integer (e.g., 3000, 8080)
PORT=3000

# Rust logging level configuration — controls what the service prints to stdout.
# Without this set, you will see NO log output. Set to "info" for normal operation.
# The service defaults to "info" internally, but setting it here makes it explicit.
# Format: string (trace, debug, info, warn, error)
RUST_LOG=info

# Optional API Key for authenticating endpoints
# If left unset, authentication is bypassed entirely.
# Format: string (e.g., your-super-secret-key-123)
# API_KEY=

# Allowed CORS origins (comma-separated). Use * to allow all origins (local dev only).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# Per-IP rate limit (requests per minute). Exceeding this returns 429 with Retry-After.
RATE_LIMIT_PER_MINUTE=60

# Indexer lag warning threshold (ledgers). Warns when indexer falls behind by this many ledgers.
# Format: integer (e.g., 100, 500)
INDEXER_LAG_WARN_THRESHOLD=100

# Log output format (text or json)
# Format: string (text, json)
RUST_LOG_FORMAT=text

# OpenTelemetry OTLP exporter endpoint (when built with otel feature)
# Format: URL (e.g., http://localhost:4317)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
