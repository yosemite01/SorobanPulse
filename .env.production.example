# ============================================================
# Production environment configuration
# Copy to .env.production and fill in real values before deploying
# NEVER commit this file with real credentials
# ============================================================

ENVIRONMENT=production

# PostgreSQL credentials
POSTGRES_USER=<PROD_USER>
POSTGRES_PASSWORD=<PROD_PASSWORD>
POSTGRES_DB=soroban_pulse

# PostgreSQL connection string — must match the credentials above
# Prefer DATABASE_URL_FILE for secret management in production
DATABASE_URL=postgres://<PROD_USER>:<PROD_PASSWORD>@<PROD_DB_HOST>:5432/soroban_pulse

# Read DATABASE_URL from a file (Docker secrets / Kubernetes secret mount)
# When set, this takes precedence over DATABASE_URL
# DATABASE_URL_FILE=/run/secrets/database_url

# PostgreSQL connection pool sizing — tune for production load
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5

# Soroban RPC endpoint — use mainnet in production
STELLAR_RPC_URL=https://mainnet.stellar.validationcloud.io/v1/<YOUR_API_KEY>

# Ledger sequence number to start indexing from (0 = latest)
START_LEDGER=0

# HTTP server port
PORT=3000

# Rust logging level — avoid debug/trace in production
RUST_LOG=warn

# API Key — required in production; use a strong random value (min 32 chars)
API_KEY=<PROD_API_KEY>

# Allowed CORS origins — never use * in production
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Per-IP rate limit (requests per minute) — tighten for production
RATE_LIMIT_PER_MINUTE=30

# Indexer lag warning threshold (ledgers)
INDEXER_LAG_WARN_THRESHOLD=50

# Log output format — json required for production log aggregation
RUST_LOG_FORMAT=json

# Trust X-Forwarded-For from upstream proxy/load balancer
BEHIND_PROXY=true

# OpenTelemetry OTLP exporter endpoint (when built with otel feature)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
