# ============================================================
# Staging environment configuration
# Copy to .env.staging and fill in real values before deploying
# ============================================================

ENVIRONMENT=staging

# PostgreSQL credentials
POSTGRES_USER=<STAGING_USER>
POSTGRES_PASSWORD=<STAGING_PASSWORD>
POSTGRES_DB=soroban_pulse_staging

# PostgreSQL connection string — must match the credentials above
DATABASE_URL=postgres://<STAGING_USER>:<STAGING_PASSWORD>@db:5432/soroban_pulse_staging

# Optional: read DATABASE_URL from a file (Docker secrets / Kubernetes secret mount)
# DATABASE_URL_FILE=/run/secrets/database_url

# PostgreSQL connection pool sizing
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# Soroban RPC endpoint — use testnet for staging
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Ledger sequence number to start indexing from (0 = latest)
START_LEDGER=0

# HTTP server port
PORT=3000

# Rust logging level
RUST_LOG=info

# API Key — required in staging; use a strong random value
API_KEY=<STAGING_API_KEY>

# Allowed CORS origins — restrict to known staging domains
ALLOWED_ORIGINS=https://staging.example.com

# Per-IP rate limit (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# Indexer lag warning threshold (ledgers)
INDEXER_LAG_WARN_THRESHOLD=100

# Log output format — use json for log aggregation in staging
RUST_LOG_FORMAT=json

# Trust X-Forwarded-For from upstream proxy/load balancer
BEHIND_PROXY=true

# OpenTelemetry OTLP exporter endpoint (when built with otel feature)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
